{
  "name": "stratify-bootstrap-theme",
  "version": "1.1.1",
  "private": true,
  "description": "Professional Bootstrap 5.3 corporate starter theme with GSAP showcase animation, accessible interactions and production tooling.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "vendor": "node tools/sync-vendor.mjs",
    "check": "node tools/check-project.mjs",
    "validate:html": "html-validate index.html",
    "test": "node tools/smoke-test.mjs && node tools/gsap-config-test.mjs",
    "quality": "npm run check && npm run validate:html && npm test && npm run build"
  },
  "dependencies": {
    "bootstrap": "5.3.8",
    "bootstrap-icons": "1.13.1",
    "gsap": "^3.13.0"
  },
  "devDependencies": {
    "html-validate": "^10.16.0",
    "jsdom": "29.1.1",
    "vite": "8.1.4"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
